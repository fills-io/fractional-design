# ─────────────────────────────────────────────────────────────────────────────
# Fills — environment variables template
#
# For LOCAL development:
#   1. Copy this file to `.env.local` (which is gitignored)
#   2. Fill in the real values (find them in 1Password / Bitwarden under "Fills")
#
# For PRODUCTION:
#   These are already set in Vercel → fills project → Settings → Environment Variables.
#   Do not commit real values to this file.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase Postgres — connection string from the Supabase dashboard
# (Settings → Database → Connection string → Transaction pooler)
DATABASE_URL=postgresql://postgres.<project-ref>:<your-password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Supabase API — public-safe values (the anon key is meant to be exposed client-side)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Apify — Pinterest scraper API token
APIFY_TOKEN=<your-apify-token>

# Google Gemini — AI text + vision (free tier covers dev usage)
# Get a key at https://aistudio.google.com → "Get API key"
GEMINI_API_KEY=<your-gemini-key>
